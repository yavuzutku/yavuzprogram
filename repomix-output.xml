<file path="css/quiz.css">
/* ── BASE ─────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #0a0a0f;
  --panel: #13131e;
  --card: #181826;
  --border: rgba(255,255,255,0.07);
  --gold: #c9a84c;
  --gold-glow: rgba(201,168,76,0.25);
  --purple: #a064ff;
  --purple-glow: rgba(160,100,255,0.25);
  --green: #22d38a;
  --red: #ff5f6d;
  --text: #f0ede8;
  --muted: #6b6880;
  --font-display: 'Syne', sans-serif;
  --font-body: 'DM Sans', sans-serif;
}

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

/* ── SCREENS ──────────────────────────────────────────── */
.screen {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 20px 40px;
}

.screen.hidden { display: none; }

/* ── START ────────────────────────────────────────────── */
.start-wrap {
  text-align: center;
  max-width: 520px;
  animation: fadeUp .6s cubic-bezier(.22,1,.36,1) both;
}

.start-badge {
  display: inline-block;
  background: rgba(160,100,255,0.12);
  border: 1px solid rgba(160,100,255,0.3);
  color: var(--purple);
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .15em;
  padding: 5px 14px;
  border-radius: 20px;
  margin-bottom: 24px;
}

.start-title {
  font-family: var(--font-display);
  font-size: clamp(42px, 8vw, 72px);
  font-weight: 800;
  line-height: 1;
  margin-bottom: 18px;
  background: linear-gradient(135deg, #fff 40%, var(--purple) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.start-sub {
  color: var(--muted);
  font-size: 15px;
  line-height: 1.7;
  margin-bottom: 40px;
}

.start-sub em { color: var(--gold); font-style: normal; }

.settings-row {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 36px;
}

.setting-box {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 20px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.setting-box label {
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 500;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 16px;
}

.stepper button {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.04);
  color: var(--text);
  font-size: 18px;
  cursor: pointer;
  transition: .2s;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.stepper button:hover {
  border-color: var(--purple);
  background: rgba(160,100,255,0.12);
  color: var(--purple);
}

.stepper span {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 700;
  min-width: 36px;
  text-align: center;
}

.btn-start {
  background: linear-gradient(135deg, var(--purple), #7040cc);
  color: white;
  border: none;
  padding: 16px 48px;
  border-radius: 14px;
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  cursor: pointer;
  transition: .25s;
  box-shadow: 0 8px 32px var(--purple-glow);
  letter-spacing: .02em;
}

.btn-start:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 48px rgba(160,100,255,0.45);
}

.start-info {
  margin-top: 16px;
  font-size: 13px;
  color: var(--muted);
}

/* ── LOADER ───────────────────────────────────────────── */
.loader-wrap {
  text-align: center;
  color: var(--muted);
}

.loader-ring {
  width: 52px;
  height: 52px;
  border: 3px solid rgba(255,255,255,0.05);
  border-top-color: var(--purple);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20px;
}

/* ── QUIZ LAYOUT ──────────────────────────────────────── */
.quiz-layout {
  width: 100%;
  max-width: 640px;
  display: flex;
  flex-direction: column;
  gap: 24px;
  animation: fadeUp .4s cubic-bezier(.22,1,.36,1) both;
}

/* Topbar */
.quiz-topbar {
  display: flex;
  align-items: center;
  gap: 16px;
}

.progress-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12px;
}

.progress-bar {
  flex: 1;
  height: 6px;
  background: rgba(255,255,255,0.07);
  border-radius: 99px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--purple), var(--gold));
  border-radius: 99px;
  transition: width .5s cubic-bezier(.22,1,.36,1);
  width: 0%;
}

.progress-label {
  font-size: 13px;
  color: var(--muted);
  white-space: nowrap;
  font-weight: 500;
}

.score-badge {
  background: rgba(34,211,138,0.1);
  border: 1px solid rgba(34,211,138,0.2);
  color: var(--green);
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  padding: 5px 14px;
  border-radius: 20px;
  white-space: nowrap;
  transition: .3s;
}

/* Question card */
.question-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 48px 40px 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: .3s;
}

.question-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(160,100,255,0.06), transparent);
  pointer-events: none;
}

.q-direction {
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--purple);
  font-weight: 600;
  margin-bottom: 20px;
  opacity: .8;
}

.q-word {
  font-family: var(--font-display);
  font-size: clamp(28px, 5vw, 48px);
  font-weight: 800;
  line-height: 1.1;
  color: var(--text);
  margin-bottom: 20px;
  word-break: break-word;
}

.q-mode-tag {
  display: inline-block;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  font-weight: 500;
  letter-spacing: .05em;
}

.q-mode-tag.multiple  { background: rgba(201,168,76,0.1);  color: var(--gold);   border: 1px solid rgba(201,168,76,0.2);  }
.q-mode-tag.typing    { background: rgba(96,200,240,0.1);   color: #60c8f0;       border: 1px solid rgba(96,200,240,0.2);  }

/* Choices */
.choices-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.choice-btn {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px 16px;
  color: var(--text);
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 400;
  cursor: pointer;
  transition: .2s;
  text-align: left;
  line-height: 1.4;
  word-break: break-word;
}

.choice-btn:hover:not(:disabled) {
  border-color: var(--purple);
  background: rgba(160,100,255,0.08);
  transform: translateY(-2px);
}

.choice-btn.correct {
  border-color: var(--green) !important;
  background: rgba(34,211,138,0.1) !important;
  color: var(--green);
}

.choice-btn.wrong {
  border-color: var(--red) !important;
  background: rgba(255,95,109,0.08) !important;
  color: var(--red);
}

.choice-btn:disabled { cursor: default; }

/* Type area */
.type-area {
  display: flex;
  gap: 12px;
}

.type-area.hidden { display: none; }
.choices-grid.hidden { display: none; }

.type-area input {
  flex: 1;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px 20px;
  color: var(--text);
  font-family: var(--font-body);
  font-size: 16px;
  outline: none;
  transition: .2s;
}

.type-area input:focus {
  border-color: var(--purple);
  box-shadow: 0 0 0 3px rgba(160,100,255,0.12);
}

