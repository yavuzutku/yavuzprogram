  display:flex; align-items:center; justify-content:center; color:var(--gold);
}
.contact-box-icon svg { width:20px; height:20px; }
.contact-box p { font-size:14px; color:var(--text-secondary); line-height:1.6; }
.contact-box a { color:var(--gold); text-decoration:none; }
.contact-box a:hover { text-decoration:underline; }

.page-footer {
  margin-top:56px; padding-top:28px; border-top:1px solid var(--border-subtle);
  display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;
}
.page-footer span { font-size:12px; color:var(--text-muted); }
.page-footer a { font-size:12px; color:var(--text-muted); text-decoration:none; transition:var(--transition); }
.page-footer a:hover { color:var(--gold); }

@media (max-width:600px) {
  .nav { padding:16px 20px; }
  .page { padding:100px 20px 80px; }
  .section { padding:22px 20px; }
  .contact-box { flex-direction:column; align-items:flex-start; }
  .page-footer { flex-direction:column; }
}
</style>
</head>
