<file path="css/artikel.css">
/* ============================================================
   artikel.css  –  Artikel Bulucu sayfası stilleri
   ============================================================ */

@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Mono:wght@300;400;500&display=swap');

:root {
  --gold:       #c9a84c;
  --gold-light: #e8c96a;
  --surface:    rgba(255,255,255,0.04);
  --border:     rgba(255,255,255,0.09);
  --text:       #e8e2d5;
  --muted:      #6b6560;
  --der:        #4a90d9;
  --die:        #d96b8a;
  --das:        #6bbf8a;
  --error:      #d97070;
}

/* ── Body: dark background everywhere, navbar dışarı taşmasın ── */
body {
  margin: 0;
  padding: 0;
  background: #0e0e0e;
}

/* Page wrapper */
.artikel-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 2rem;
  background: #0e0e0e;
  font-family: 'DM Mono', monospace;
}

.artikel-page::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(201,168,76,0.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 80%, rgba(74,144,217,0.04) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

.artikel-back,
.artikel-container {
  position: relative;
  z-index: 1;
}

/* Back button */
.artikel-back {
  width: 100%;
  max-width: 540px;
  margin-bottom: 1.5rem;
}

.back-link {
  color: var(--muted);
  text-decoration: none;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: color 0.2s;
}

.back-link:hover { color: var(--gold); }

/* Main card container */
.artikel-container {
  width: 100%;
  max-width: 540px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2.4rem 2rem 2rem;
  backdrop-filter: blur(12px);
}

/* Header */
.artikel-header {
  text-align: center;
  margin-bottom: 2rem;
}

.flag {
  display: flex;
  justify-content: center;
  margin-bottom: 1.2rem;
}

.flag-stripe { width: 28px; height: 6px; }
.flag-stripe.s1 { background: #1a1a1a; border: 1px solid #333; }
.flag-stripe.s2 { background: var(--gold); }
.flag-stripe.s3 { background: #c0392b; }

.artikel-header h1 {
  font-family: 'Playfair Display', serif;
  font-size: 2.2rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text);
  line-height: 1.1;
}

.artikel-header h1 span {
  color: var(--gold);
  font-style: italic;
}

.artikel-header p {
  margin-top: 0.5rem;
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

/* Divider */
.divider {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  margin: 0 0 1.8rem;
}
.divider::before, .divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--border), transparent);
}
.diamond {
  width: 6px; height: 6px;
  background: var(--gold);
  transform: rotate(45deg);
  opacity: 0.6;
}

/* Input */
.input-group {
  display: flex;
  gap: 0.6rem;
  align-items: stretch;
}

.input-wrapper { flex: 1; }

.input-wrapper input[type="text"] {
  width: 100%;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  color: var(--text);
  font-family: 'Playfair Display', serif;
  font-size: 1.05rem;
  padding: 0.85rem 1rem;
  border-radius: 8px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  box-sizing: border-box;
}

.input-wrapper input[type="text"]::placeholder {
  color: var(--muted);
  font-style: italic;
  font-size: 0.92rem;
}

.input-wrapper input[type="text"]:focus {
  border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
}

.search-btn {
  background: var(--gold);
  color: #0e0e0e;
  border: none;
  padding: 0 1.3rem;
  border-radius: 8px;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s, transform 0.1s;
}

.search-btn:hover  { background: var(--gold-light); }
.search-btn:active { transform: scale(0.97); }
.search-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

/* Loading */
.loading {
  margin-top: 1.6rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  color: var(--muted);
  font-size: 0.74rem;
  letter-spacing: 0.08em;
}

.dots span {
  display: inline-block;
  width: 4px; height: 4px;
  background: var(--gold);
  border-radius: 50%;
  animation: dotBounce 1.2s ease-in-out infinite;
}
.dots span:nth-child(2) { animation-delay: 0.2s; }
.dots span:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
  40%           { transform: translateY(-5px); opacity: 1; }
}

/* Error */
.error-msg {
  margin-top: 1.6rem;
  padding: 1rem 1.2rem;
  background: rgba(217,112,112,0.06);
  border: 1px solid rgba(217,112,112,0.2);
  border-radius: 8px;
  color: var(--error);
  font-size: 0.78rem;
  letter-spacing: 0.03em;
  line-height: 1.7;
  animation: slideUp 0.3s ease;
}

/* Result card */
.result-card {
  margin-top: 1.6rem;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 10px;
  overflow: hidden;
  animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

.result-top {
  padding: 1.5rem 1.5rem 1.1rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: flex-end;
  gap: 0.8rem;
}

.artikel-badge {
  font-family: 'Playfair Display', serif;
  font-size: 3rem;
  font-weight: 700;
  font-style: italic;
  line-height: 1;
  transition: color 0.3s;
}
.artikel-badge.der { color: var(--der); }
.artikel-badge.die { color: var(--die); }
.artikel-badge.das { color: var(--das); }

.result-word-block {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding-bottom: 0.2rem;
}

.result-word {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem;
  color: var(--text);
}

.result-genus-label {
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
}

.result-bottom {
  padding: 0.9rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.genus-pill {
  display: inline-block;
  font-size: 0.63rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.2rem 0.55rem;
  border-radius: 3px;
  font-weight: 600;
}
.genus-pill.der { background: rgba(74,144,217,0.12);  color: var(--der); border: 1px solid rgba(74,144,217,0.25); }
.genus-pill.die { background: rgba(217,107,138,0.12); color: var(--die); border: 1px solid rgba(217,107,138,0.25); }
.genus-pill.das { background: rgba(107,191,138,0.12); color: var(--das); border: 1px solid rgba(107,191,138,0.25); }

.genus-name {
  font-size: 0.7rem;
  color: var(--muted);
}

/* Legend */
.legend {
  margin-top: 2rem;
  display: flex;
  justify-content: center;
  gap: 1.4rem;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.63rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
}

.legend-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
}
.legend-dot.der { background: var(--der); }
.legend-dot.die { background: var(--die); }
.legend-dot.das { background: var(--das); }

/* Footer */
.artikel-footer {
  margin-top: 1.5rem;
  text-align: center;
  font-size: 0.6rem;
  color: var(--muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.5;
}

/* Utility */
.hidden { display: none !important; }

/* ── Wiktionary link satırı ── */
.result-link-row {
  padding: 0.75rem 1.5rem 1rem;
  border-top: 1px solid var(--border);
}

.wikt-link {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.73rem;
  letter-spacing: 0.06em;
  color: var(--gold);
  text-decoration: none;
  text-transform: uppercase;
  opacity: 0.75;
  transition: opacity 0.2s, gap 0.2s;
}

.wikt-link:hover { opacity: 1; }

.wikt-link:hover .wikt-arrow { transform: translateX(4px); }

.wikt-arrow {
  display: inline-block;
  transition: transform 0.2s;
}
</file>

