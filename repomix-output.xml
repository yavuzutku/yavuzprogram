<file path="css/okuma.css">
body {
  margin: 0;
  font-family: Inter, sans-serif;
  background: #0a0a0f;
  color: white;
}

/* =========================
   OKUMA ALANI
========================= */

.reader-container {
  display: flex;
  justify-content: center;
  padding: 60px 20px;
}

.reader-card {
  width: 90%;
  max-width: 800px;
  height: 70vh;
  background: #12121a;
  padding: 40px;
  border-radius: 20px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
  font-size: 20px;
  line-height: 1.8;
  overflow-y: auto;
  transition: 0.3s ease;
}

.reader-card::-webkit-scrollbar {
  width: 8px;
}

.reader-card::-webkit-scrollbar-thumb {
  background: #c9a84c;
  border-radius: 10px;
}

/* =========================
   TOOLBAR — ORTAK
========================= */

.reader-toolbar {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 12px;
  background: #12121a;
  padding: 15px;
  border-radius: 20px;
  box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
}

.reader-toolbar button {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 12px;
  border: none;
  border-radius: 12px;
  background: #1e1e2a;
  color: white;
  font-size: 18px;
  cursor: pointer;
  transition: 0.3s;
  white-space: nowrap;
}

.reader-toolbar button:hover {
  background: #c9a84c;
  transform: scale(1.08);
}

/* Sol toolbar */
.left-toolbar {
  left: 30px;
}

.left-toolbar button {
  font-size: 20px;
}

.toolbar-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.3px;
  color: #aaa;
}

.left-toolbar button:hover .toolbar-label {
  color: white;
}

/* Sağ toolbar */
.right-toolbar {
  right: 30px;
}

/* =========================
   GERİ BUTONU
========================= */

.back-bar {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
}

.back-bar button {
  padding: 12px 24px;
  background: #c9a84c;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  font-weight: 600;
  color: #0a0a0f;
  font-size: 15px;
  transition: 0.3s;
}

.back-bar button:hover {
  transform: scale(1.05);
}

/* =========================
   LIGHT MODE
========================= */

.light-mode {
  background: white !important;
  color: black !important;
}

.light-mode .reader-card {
  background: #f4f4f4;
  color: black;
}

/* =========================
   KELİME EKLEME MODALI
========================= */

.word-modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  z-index: 10000;
  align-items: center;
  justify-content: center;
}

.word-modal-overlay.active {
  display: flex;
}

.word-modal {
  background: #1a1a26;
  border: 1px solid rgba(201, 168, 76, 0.3);
  border-radius: 20px;
  padding: 28px 32px;
  width: 360px;
  max-width: 90vw;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.7);
  animation: modalIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.88) translateY(16px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.word-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  font-size: 16px;
  font-weight: 600;
  color: #c9a84c;
}

.word-modal-close {
  background: none;
  border: none;
  color: #666;
  font-size: 18px;
  cursor: pointer;
  transition: 0.2s;
  padding: 0;
  line-height: 1;
}

.word-modal-close:hover {
  color: white;
}

.word-modal-word {
  font-size: 22px;
  font-weight: 700;
  color: #e2e8f0;
  margin-bottom: 18px;
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.07);
  word-break: break-word;
}

.word-modal-input {
  width: 100%;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  font-size: 15px;
  font-family: inherit;
  padding: 12px 14px;
  outline: none;
  transition: 0.2s;
  margin-bottom: 20px;
}

.word-modal-input::placeholder {
  color: #555;
}

.word-modal-input:focus {
  border-color: #c9a84c;
  background: rgba(255, 255, 255, 0.08);
}

.word-modal-actions {
  display: flex;
  gap: 10px;
}

.word-modal-cancel {
  flex: 1;
  padding: 11px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: #aaa;
  font-size: 14px;
  font-family: inherit;
  cursor: pointer;
  transition: 0.2s;
}

.word-modal-cancel:hover {
  background: rgba(255, 255, 255, 0.1);
  color: white;
}

.word-modal-save {
  flex: 2;
  padding: 11px;
  background: #c9a84c;
  border: none;
  border-radius: 10px;
  color: #0a0a0f;
  font-size: 14px;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  transition: 0.2s;
}

.word-modal-save:hover {
  background: #e2bc5a;
  transform: scale(1.02);
}

.word-modal-save:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}
