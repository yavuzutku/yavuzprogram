<file path="css/singleadd.css">
body {
  margin: 0;
  font-family: 'DM Sans', sans-serif;
  background: linear-gradient(135deg, #0a0a0f, #12121a);
  color: white;
  min-height: 100vh;
}

/* CONTAINER */
.singleadd-container {
  max-width: 560px;
  margin: 100px auto;
  padding: 20px;
}

/* GERİ BUTONU */
.back-btn {
  background: none;
  border: 1px solid rgba(255, 255, 255, 0.15);
  color: #aaa;
  padding: 8px 18px;
  border-radius: 10px;
  cursor: pointer;
  font-size: 14px;
  font-family: inherit;
  transition: 0.25s;
  margin-bottom: 40px;
  display: inline-block;
}

.back-btn:hover {
  border-color: #c9a84c;
  color: #c9a84c;
}

/* HERO */
.singleadd-hero h1 {
  font-size: 34px;
  margin-bottom: 8px;
}

.singleadd-hero p {
  color: #aaa;
  font-size: 16px;
  margin-bottom: 48px;
}

/* ADIM BLOĞU */
.step {
  display: flex;
  flex-direction: column;
  gap: 16px;
  animation: fadeSlideIn 0.3s ease;
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hidden {
  display: none !important;
}

/* LABEL */
.step-label {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #c9a84c;
}

/* KELİME ÖNİZLEME */
.word-preview {
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.02em;
  margin-bottom: 4px;
}

/* INPUT */
.word-input {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 14px;
  padding: 16px 20px;
  font-size: 20px;
  color: white;
  font-family: inherit;
  outline: none;
  transition: border-color 0.25s, box-shadow 0.25s;
  width: 100%;
  box-sizing: border-box;
}

.word-input::placeholder {
  color: rgba(255, 255, 255, 0.25);
}

.word-input:focus {
  border-color: #c9a84c;
  box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.15);
}

/* ── ÇEVİRİ ÖNERİSİ ── */
.translate-hint {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px dashed rgba(255, 255, 255, 0.12);
  border-radius: 10px;
  font-size: 14px;
  animation: fadeSlideIn 0.3s ease;
}

.hint-label {
  color: #888;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  white-space: nowrap;
}

.hint-text {
  color: #c9a84c;
  font-style: italic;
  font-size: 15px;
}

.hint-text.hint-error {
  color: #888;
  font-style: normal;
}

/* ANA BUTON */
.primary-btn {
  background: linear-gradient(135deg, #c9a84c, #a87c2a);
  border: none;
  border-radius: 14px;
  padding: 16px 28px;
  font-size: 16px;
  font-weight: 600;
  font-family: inherit;
  color: #fff;
  cursor: pointer;
  transition: opacity 0.25s, transform 0.2s;
  align-self: flex-start;
}

.primary-btn:hover:not(:disabled) {
  opacity: 0.9;
  transform: translateY(-2px);
}

.primary-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* DURUM MESAJLARI */
.status-msg {
  margin-top: 24px;
  padding: 14px 20px;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 500;
  animation: fadeSlideIn 0.3s ease;
}

.status-msg.success {
  background: rgba(52, 199, 89, 0.12);
  border: 1px solid rgba(52, 199, 89, 0.35);
  color: #34c759;
}

.status-msg.error {
  background: rgba(255, 69, 58, 0.12);
  border: 1px solid rgba(255, 69, 58, 0.35);
  color: #ff453a;
}
/* =========================
   TAG SEÇİCİ
========================= */

.step-tag-section {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.tag-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag-chip {
  padding: 6px 14px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.04);
  color: #888;
  font-size: 13px;
  font-family: inherit;
  cursor: pointer;
  transition: 0.2s;
  font-weight: 500;
}

.tag-chip:hover {
  border-color: #c9a84c;
  color: #c9a84c;
}

.tag-chip.selected {
  background: #c9a84c;
  border-color: #c9a84c;
  color: #0a0a0f;
  font-weight: 700;
}
