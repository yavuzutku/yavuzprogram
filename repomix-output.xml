  border: none;
  border-radius: 14px;
  padding: 16px 24px;
  color: white;
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: .2s;
  white-space: nowrap;
}

.btn-check:hover { background: #8a50e8; transform: translateY(-2px); }
.btn-check:disabled { opacity: .5; cursor: default; transform: none; }

/* Feedback */
.feedback {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 24px 28px;
  display: flex;
  align-items: center;
  gap: 16px;
  animation: fadeUp .3s ease both;
}

.feedback.hidden { display: none; }

.feedback.correct-fb { border-color: rgba(34,211,138,0.3); background: rgba(34,211,138,0.05); }
.feedback.wrong-fb   { border-color: rgba(255,95,109,0.3);  background: rgba(255,95,109,0.05);  }

.feedback-icon { font-size: 28px; flex-shrink: 0; }

.feedback-text { flex: 1; font-size: 14px; line-height: 1.6; color: var(--muted); }
.feedback-text strong { color: var(--text); font-size: 15px; }

.btn-next {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 10px 20px;
  color: var(--text);
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: .2s;
  white-space: nowrap;
  flex-shrink: 0;
}

.btn-next:hover { border-color: var(--purple); color: var(--purple); }

/* ── RESULT ───────────────────────────────────────────── */
.result-wrap {
  text-align: center;
  max-width: 480px;
  animation: fadeUp .6s cubic-bezier(.22,1,.36,1) both;
}

.result-emoji {
  font-size: 64px;
  margin-bottom: 16px;
  animation: bounce .6s ease both .3s;
}

.result-title {
  font-family: var(--font-display);
  font-size: 48px;
  font-weight: 800;
  margin-bottom: 16px;
}

.result-score {
  font-family: var(--font-display);
  font-size: 72px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--gold), var(--purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 12px;
}

.result-msg { color: var(--muted); font-size: 16px; margin-bottom: 32px; }

.result-breakdown {
  display: flex;
  gap: 16px;
  justify-content: center;
  margin-bottom: 36px;
}

.rb-item {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.rb-num { font-family: var(--font-display); font-size: 28px; font-weight: 800; }
.rb-num.green  { color: var(--green); }
.rb-num.red    { color: var(--red);   }
.rb-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; }

.result-actions { display: flex; gap: 12px; justify-content: center; }

.btn-restart {
  background: linear-gradient(135deg, var(--purple), #7040cc);
  border: none;
  border-radius: 14px;
  padding: 14px 32px;
  color: white;
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  transition: .25s;
  box-shadow: 0 8px 24px var(--purple-glow);
}

.btn-restart:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(160,100,255,0.4); }

.btn-home {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 14px 32px;
  color: var(--muted);
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: .2s;
}

.btn-home:hover { border-color: var(--text); color: var(--text); }

/* ── ANIMATIONS ───────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0);     }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0);    }
  50%       { transform: translateY(-16px); }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-6px); }
  40%, 80% { transform: translateX(6px); }
}

.shake { animation: shake .35s ease both; }

/* ── RESPONSIVE ───────────────────────────────────────── */
@media (max-width: 500px) {
  .choices-grid { grid-template-columns: 1fr; }
  .type-area { flex-direction: column; }
  .question-card { padding: 32px 24px; }
  .quiz-layout { gap: 16px; }
}
