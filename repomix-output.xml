<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════
   TOKENS
══════════════════════════════════════════ */
:root {
  --font-display: 'Syne', sans-serif;
  --font-body:    'DM Sans', sans-serif;
  --bg-base:      #070709;
  --bg-surface:   rgba(255,255,255,0.035);
  --bg-hover:     rgba(255,255,255,0.06);
  --border-subtle: rgba(255,255,255,0.07);
  --border-hover:  rgba(255,255,255,0.16);
  --text-primary:   #f0eee8;
  --text-secondary: rgba(240,238,232,0.55);
  --text-muted:     rgba(240,238,232,0.32);
  --gold:        #c9a84c;
  --gold-light:  #e8c97a;
  --gold-dim:    rgba(201,168,76,0.15);
  --blue:        #60c8f0;
  --violet:      #a064ff;
  --green:       #4fd69c;
  --rose:        #f07068;
  --amber:       #ffd250;
  --radius-card: 16px;
  --transition:  0.3s cubic-bezier(0.4,0,0.2,1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg-base);
  color: var(--text-primary);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ── Background ── */
.bg-canvas { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
.bg-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
  background-size: 56px 56px;
  mask-image: radial-gradient(ellipse 100% 70% at 50% 0%, black 20%, transparent 100%);
}
.bg-glow {
  position: absolute; border-radius: 50%; filter: blur(130px);
  animation: drift 14s ease-in-out infinite alternate;
  pointer-events: none;
}
.bg-glow--1 { width:700px; height:700px; top:-300px; left:-150px; background:radial-gradient(circle,#c9a84c,transparent 70%); opacity:0.09; }
.bg-glow--2 { width:500px; height:500px; top:20%; right:-200px; background:radial-gradient(circle,#60c8f0,transparent 70%); opacity:0.06; animation-delay:-5s; }
.bg-glow--3 { width:400px; height:400px; bottom:5%; left:30%; background:radial-gradient(circle,#a064ff,transparent 70%); opacity:0.05; animation-delay:-10s; }
@keyframes drift { from{transform:translate(0,0) scale(1)} to{transform:translate(30px,25px) scale(1.06)} }

/* ══════════════════════════════════════════
   NAV
══════════════════════════════════════════ */
.nav {
  position: fixed; top:0; left:0; right:0; z-index:100;
  padding: 18px 48px;
  display: flex; align-items:center; justify-content:space-between;
  border-bottom: 1px solid var(--border-subtle);
  background: rgba(7,7,9,0.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.nav-logo { display:flex; align-items:center; gap:11px; text-decoration:none; }
.nav-logo-icon {
  width:36px; height:36px;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  border-radius:10px; display:flex; align-items:center; justify-content:center;
  box-shadow: 0 4px 20px rgba(201,168,76,0.25);
}
.nav-logo-icon svg { width:19px; height:19px; }
.nav-logo-name { font-family:var(--font-display); font-size:17px; font-weight:800; color:var(--text-primary); letter-spacing:-0.02em; }
.nav-cta {
  display: flex; align-items:center; gap:10px;
  padding: 9px 22px;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: #0a0a0f; font-size:13.5px; font-weight:600;
  border-radius: 999px; text-decoration:none;
  box-shadow: 0 4px 20px rgba(201,168,76,0.3);
  transition: var(--transition);
  letter-spacing: -0.01em;
}
.nav-cta:hover { transform:translateY(-1px); box-shadow:0 8px 28px rgba(201,168,76,0.4); }
.nav-cta svg { width:14px; height:14px; }

/* ══════════════════════════════════════════
   HERO
══════════════════════════════════════════ */
.hero {
  position: relative; z-index:1;
  max-width: 900px; margin:0 auto;
  padding: 160px 32px 80px;
  text-align: center;
}

.hero-eyebrow {
  display: inline-flex; align-items:center; gap:8px;
  font-size:11.5px; font-weight:500; letter-spacing:0.14em; text-transform:uppercase;
  color:var(--text-muted); margin-bottom:28px;
  padding:6px 16px 6px 12px;
  border:1px solid var(--border-subtle); border-radius:999px;
  background:rgba(255,255,255,0.025);
  animation: fadeUp 0.6s cubic-bezier(0.4,0,0.2,1) both;
}
.eyebrow-dot { width:6px; height:6px; border-radius:50%; background:var(--gold); box-shadow:0 0 10px var(--gold); animation:pulse 2.5s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.45;transform:scale(0.75)} }

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(44px, 7vw, 88px);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.0;
  margin-bottom: 24px;
  animation: fadeUp 0.65s 0.08s cubic-bezier(0.4,0,0.2,1) both;
}
.hero-title-accent {
  background: linear-gradient(135deg, #c9a84c 0%, #f0d080 45%, #c9a84c 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; background-size:200% 200%;
  animation: fadeUp 0.65s 0.08s cubic-bezier(0.4,0,0.2,1) both, shimmer 5s ease-in-out infinite;
}
@keyframes shimmer { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }

.hero-sub {
  font-size: clamp(15px, 2vw, 18px);
  line-height: 1.7;
  color: var(--text-secondary);
  max-width: 560px; margin:0 auto 40px;
  animation: fadeUp 0.65s 0.14s cubic-bezier(0.4,0,0.2,1) both;
}

.hero-actions {
  display: flex; align-items:center; justify-content:center; gap:14px; flex-wrap:wrap;
  animation: fadeUp 0.65s 0.2s cubic-bezier(0.4,0,0.2,1) both;
}
.btn-primary {
  display: flex; align-items:center; gap:10px;
  padding: 14px 30px;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: #0a0a0f; font-size:15px; font-weight:700;
  border-radius:12px; text-decoration:none;
  box-shadow: 0 6px 28px rgba(201,168,76,0.35);
  transition: var(--transition); letter-spacing:-0.01em;
}
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 12px 36px rgba(201,168,76,0.45); }
.btn-primary svg { width:16px; height:16px; }
.btn-secondary {
  display: flex; align-items:center; gap:8px;
  padding: 14px 26px; font-size:15px; font-weight:500;
  color: var(--text-secondary); background: var(--bg-surface);
  border:1px solid var(--border-subtle); border-radius:12px; text-decoration:none;
  transition: var(--transition);
}
.btn-secondary:hover { color:var(--text-primary); border-color:var(--border-hover); background:var(--bg-hover); }

/* ── Hero stats ── */
.hero-stats {
  display: flex; align-items:center; justify-content:center; gap:0;
  margin-top: 64px;
  animation: fadeUp 0.65s 0.26s cubic-bezier(0.4,0,0.2,1) both;
}
.hstat { display:flex; flex-direction:column; align-items:center; gap:3px; padding:0 32px; }
.hstat-num { font-family:var(--font-display); font-size:28px; font-weight:800; letter-spacing:-0.03em; color:var(--text-primary); line-height:1; }
.hstat-label { font-size:11px; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-muted); }
.hstat-div { width:1px; height:40px; background:var(--border-subtle); }

@keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }

/* ══════════════════════════════════════════
   FEATURES
══════════════════════════════════════════ */
.section {
  position: relative; z-index:1;
  max-width: 1120px; margin:0 auto;
  padding: 0 32px 100px;
}

.section-header {
  text-align:center; margin-bottom:48px;
}
.section-label {
  display:inline-block;
  font-size:11px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase;
  color:var(--gold); margin-bottom:14px; opacity:0.8;
}
.section-title {
  font-family:var(--font-display); font-size:clamp(26px,4vw,40px); font-weight:800;
  letter-spacing:-0.03em; color:var(--text-primary); line-height:1.1;
}
.section-title span { color:var(--text-secondary); font-weight:700; }

/* Feature grid */
.features-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

@media (max-width:1000px) { .features-grid { grid-template-columns:repeat(2,1fr); } }
@media (max-width:560px)  { .features-grid { grid-template-columns:1fr; } }

.feat-card {
  padding: 28px 24px 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-card);
  transition: var(--transition);
  position: relative; overflow:hidden;
}
.feat-card::before {
  content:''; position:absolute; inset:0; border-radius:var(--radius-card);
  opacity:0; transition: opacity 0.4s;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, var(--accent, rgba(201,168,76,0.07)), transparent);
}
.feat-card:hover { border-color:var(--border-hover); background:var(--bg-hover); transform:translateY(-4px); box-shadow:0 24px 48px -12px rgba(0,0,0,0.5); }
.feat-card:hover::before { opacity:1; }

.feat-card--gold  { --accent: rgba(201,168,76,0.08); }
.feat-card--blue  { --accent: rgba(96,200,240,0.07); }
.feat-card--green { --accent: rgba(79,214,156,0.07); }
.feat-card--violet{ --accent: rgba(160,100,255,0.07); }
.feat-card--rose  { --accent: rgba(240,112,104,0.07); }
.feat-card--amber { --accent: rgba(255,210,80,0.07); }

.feat-icon {
  width:44px; height:44px; border-radius:11px;
  border:1px solid var(--border-subtle);
  background:rgba(255,255,255,0.04);
  display:flex; align-items:center; justify-content:center;
  margin-bottom:18px; font-size:20px; transition:var(--transition);
}
.feat-card:hover .feat-icon { border-color:var(--border-hover); }
.feat-card--gold:hover  .feat-icon { background:rgba(201,168,76,0.1); }
.feat-card--blue:hover  .feat-icon { background:rgba(96,200,240,0.1); }
.feat-card--green:hover .feat-icon { background:rgba(79,214,156,0.1); }
.feat-card--violet:hover .feat-icon { background:rgba(160,100,255,0.1); }
.feat-card--rose:hover  .feat-icon { background:rgba(240,112,104,0.1); }
.feat-card--amber:hover .feat-icon { background:rgba(255,210,80,0.1); }

.feat-title {
  font-family:var(--font-display); font-size:16px; font-weight:700;
  letter-spacing:-0.01em; color:var(--text-primary); margin-bottom:8px;
}
.feat-desc { font-size:13.5px; line-height:1.65; color:var(--text-secondary); }
.feat-tag {
  display:inline-block; margin-top:14px;
  font-size:10px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase;
  padding:3px 10px; border-radius:999px; border:1px solid var(--border-subtle);
  color:var(--text-muted); transition:var(--transition);
}
.feat-card--gold:hover  .feat-tag { color:var(--gold);   border-color:rgba(201,168,76,0.3); }
.feat-card--blue:hover  .feat-tag { color:var(--blue);   border-color:rgba(96,200,240,0.3); }
.feat-card--green:hover .feat-tag { color:var(--green);  border-color:rgba(79,214,156,0.3); }
.feat-card--violet:hover .feat-tag{ color:var(--violet); border-color:rgba(160,100,255,0.3); }
.feat-card--rose:hover  .feat-tag { color:var(--rose);   border-color:rgba(240,112,104,0.3); }
.feat-card--amber:hover .feat-tag { color:var(--amber);  border-color:rgba(255,210,80,0.3); }

/* ══════════════════════════════════════════
   CTA BANNER
══════════════════════════════════════════ */
.cta-banner {
  position:relative; z-index:1;
  max-width:1120px; margin:0 auto;
  padding:0 32px 100px;
}
.cta-inner {
  padding:56px 48px;
  background: var(--bg-surface);
  border:1px solid rgba(201,168,76,0.18);
  border-radius:24px;
  text-align:center;
  position:relative; overflow:hidden;
}
.cta-inner::before {
  content:''; position:absolute; inset:0;
  background: radial-gradient(ellipse 70% 80% at 50% 0%, rgba(201,168,76,0.07), transparent 60%);
  pointer-events:none;
}
.cta-title {
  font-family:var(--font-display); font-size:clamp(24px,4vw,40px);
  font-weight:800; letter-spacing:-0.03em; margin-bottom:14px;
}
.cta-sub { font-size:15px; color:var(--text-secondary); margin-bottom:32px; line-height:1.6; }
.cta-note { margin-top:16px; font-size:12px; color:var(--text-muted); }

/* ══════════════════════════════════════════
   FOOTER
══════════════════════════════════════════ */
.footer {
  position:relative; z-index:1;
  border-top:1px solid var(--border-subtle);
  padding:32px 48px;
  display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;
}
.footer-logo { display:flex; align-items:center; gap:9px; }
.footer-logo-icon {
  width:28px; height:28px; border-radius:7px;
  background:linear-gradient(135deg, var(--gold), var(--gold-light));
  display:flex; align-items:center; justify-content:center;
}
.footer-logo-icon svg { width:14px; height:14px; }
.footer-logo-name { font-family:var(--font-display); font-size:14px; font-weight:800; color:var(--text-primary); }
.footer-links { display:flex; gap:24px; }
.footer-links a { font-size:13px; color:var(--text-muted); text-decoration:none; transition:var(--transition); }
.footer-links a:hover { color:var(--gold); }
.footer-copy { font-size:12px; color:var(--text-muted); }

@media (max-width:600px) {
  .nav { padding:16px 20px; }
  .hero { padding:130px 20px 60px; }
  .hero-stats { flex-wrap:wrap; gap:16px; }
  .hstat-div { display:none; }
  .section, .cta-banner { padding-left:20px; padding-right:20px; }
  .cta-inner { padding:40px 24px; }
  .footer { padding:24px 20px; flex-direction:column; align-items:flex-start; }
  .hero-actions { flex-direction:column; align-items:stretch; }
  .btn-primary, .btn-secondary { justify-content:center; }
}
</style>
